        },
        "summary": {
          "type": "string"
        },
        "publishedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updatedAt": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "EAA",
            "AX-readiness",
            "AI Ops",
            "Site Factory",
            "MCP-Commerce",
            "Case Study",
            "CENTAUR"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "image": {
          "type": "string"
        },
        "imageAlt": {
          "type": "string"
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "author": {
          "type": "string",
          "default": "Chris Conen"
        },
        "readingTime": {
          "type": "number"
        },
        "$schema": {
          "type": "string"
        }
