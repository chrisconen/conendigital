---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const categories = [...new Set(posts.map((p) => p.data.category))].map((cat) => ({
  name: cat,
  count: posts.filter((p) => p.data.category === cat).length,
  slug: cat.toLowerCase().replace(/\s+/g, '-'),
}));

const featured = posts[0];
const rest = posts.slice(1);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Blog"
  description="Webfejlesztés, AI Ops, EAA megfelelés, AX-readiness — szakmai cikkek a Conen Digital CENTAUR keretrendszeréből."
>
  <!-- Hero -->
  <section class="bh">
    <div class="container">
      <div class="bh__eyebrow reveal">[ Conen Digital // Blog ]</div>
      <h1 class="bh__title reveal reveal-delay-1">
        Ahol a <em>kód</em> találkozik<br/>a <em>stratégiával</em>.
      </h1>
      <p class="bh__lead reveal reveal-delay-2">
        Nem általános tartalom. A saját projektjeinkből származó tapasztalat, mérhető eredményekkel.
        Webfejlesztés, AI-integráció, EAA-megfelelés, AX-readiness.
      </p>

      {categories.length > 0 && (
        <nav class="bh__cats reveal reveal-delay-3" aria-label="Kategóriák">
          <a href={base} class="bh__cat bh__cat--active">Mind <span>{posts.length}</span></a>
          {categories.map((cat) => (
            <a href={`${base}/category/${cat.slug}`} class="bh__cat">
              {cat.name} <span>{cat.count}</span>
            </a>
          ))}
        </nav>
      )}

      <div class="bh__line" aria-hidden="true"></div>
    </div>
  </section>

  <!-- Posts -->
  <section class="bl">
    <div class="container">
      {posts.length === 0 ? (
        <div class="bl__empty reveal">
          <div class="bl__empty-icon">∅</div>
          <p>Hamarosan megjelennek az első cikkek.</p>
        </div>
      ) : (
        <div class="bl__grid">
          {featured && <PostCard post={featured} featured />}
          {rest.map((post) => <PostCard post={post} />)}
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="bc reveal">
    <div class="container">
      <div class="bc__card">
        <div class="bc__label">CENTAUR keretrendszer</div>
        <h2 class="bc__title">Tervezd meg a weboldalad <em>két verzióban</em>, egyszerre.</h2>
        <p class="bc__text">Az IKER konfigurátor élő preview-val, variant-compare-rel és audit-metrikákkal dolgozik.</p>
        <a href="https://app.conendigital.hu" class="bc__btn">IKER megnyitása →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .bh { padding: 7rem 0 3rem; text-align: center; }
  .bh__eyebrow {
    font-family: var(--font-mono); font-size: .72rem;
    color: var(--cyan); letter-spacing: .2em; text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .bh__title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 700; line-height: .95; letter-spacing: -.035em;
    margin-bottom: 2rem;
  }
  .bh__title em {
    font-style: italic;
    background: linear-gradient(90deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .bh__lead {
    font-size: 1.1rem; color: rgba(255,255,255,.5); line-height: 1.75;
    max-width: 56ch; margin: 0 auto 2.5rem;
  }
  .bh__cats {
    display: flex; flex-wrap: wrap; justify-content: center; gap: .5rem;
    margin-bottom: 3rem;
  }
  .bh__cat {
    font-family: var(--font-mono); font-size: .68rem; letter-spacing: .1em;
    text-transform: uppercase; padding: .5rem 1rem;
    border: 1px solid rgba(255,255,255,.06); color: rgba(255,255,255,.4);
    transition: all .3s; border-radius: 2px;
  }
  .bh__cat:hover, .bh__cat--active { border-color: var(--cyan); color: var(--cyan); }
  .bh__cat span {
    font-size: .55rem; opacity: .4; margin-left: .3rem;
  }
  .bh__line {
    height: 1px; max-width: 200px; margin: 0 auto;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    opacity: .3;
  }

  /* Posts grid */
  .bl { padding: 3rem 0 4rem; }
  .bl__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gutter);
  }
  .bl__empty {
    text-align: center; padding: 6rem 0;
    font-family: var(--font-mono); color: var(--gray-text);
  }
  .bl__empty-icon {
    font-size: 3rem; margin-bottom: 1rem; opacity: .3;
  }

  /* CTA banner */
  .bc { padding: 2rem 0 4rem; }
  .bc__card {
    padding: 3.5rem;
    background: linear-gradient(135deg, rgba(0,240,255,.04), rgba(191,0,255,.03));
    border: 1px solid rgba(0,240,255,.1);
    border-radius: 3px; text-align: center;
    position: relative; overflow: hidden;
  }
  .bc__card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--cyan), var(--magenta), transparent);
  }
  .bc__label {
    font-family: var(--font-mono); font-size: .65rem; letter-spacing: .18em;
    text-transform: uppercase; color: var(--cyan); margin-bottom: 1.25rem;
  }
  .bc__title {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 700;
    line-height: 1.15; margin-bottom: 1rem;
  }
  .bc__title em {
    font-style: normal;
    background: linear-gradient(90deg, var(--cyan), var(--magenta));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .bc__text {
    font-size: .95rem; color: rgba(255,255,255,.5); max-width: 48ch;
    margin: 0 auto 1.75rem; line-height: 1.6;
  }
  .bc__btn {
    display: inline-block;
    font-family: var(--font-mono); font-size: .75rem; letter-spacing: .1em;
    text-transform: uppercase; padding: .85rem 2rem;
    border: 1px solid var(--cyan); color: var(--cyan); transition: all .3s;
  }
  .bc__btn:hover { background: var(--cyan); color: var(--black); }

  @media (max-width: 768px) {
    .bh { padding: 5rem 0 2rem; }
    .bl__grid { grid-template-columns: 1fr; }
    .bc__card { padding: 2rem 1.5rem; }
  }
</style>
